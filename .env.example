QUOTE_TOOL_ARTIFACT_ROOT=./artifacts
QUOTE_TOOL_STORAGE_ROOT=./storage
QUOTE_TOOL_HEADED=false
QUOTE_TOOL_PORT=4310
QUOTE_TOOL_SESSION_SECRET=

# Optional. If omitted, Quoteget will generate a disposable Mailinator address per Hubs run.
HUBS_EMAIL=
HUBS_UNITS=mm
HUBS_FINISH_SLUG=as-machined-standard
# Optional override for the default Hubs Aluminum 6061 subset ID.
HUBS_MATERIAL_SUBSET_ID=86
HUBS_TECHNOLOGY_ID=1

# Optional Browserbase-backed RapidDirect pilot settings.
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=
BROWSERBASE_REGION=us-west-2
BROWSERBASE_KEEP_ALIVE=false
BROWSERBASE_ENABLE_PROXIES=false
BROWSERBASE_SOLVE_CAPTCHAS=true
BROWSERBASE_ADVANCED_STEALTH=false

XOMETRY_STORAGE_STATE=./storage/auth/xometry.json
RAPIDDIRECT_STORAGE_STATE=./storage/auth/rapiddirect.json
PROTOLABS_STORAGE_STATE=./storage/auth/protolabs.json
# Optional. If set, Protolabs account creation can solve reCAPTCHA during a fresh-session signup.
TWOCAPTCHA_API_KEY=

# AI agent model for browser vendor automation (Stagehand).
# Recommended: gemini-2.5-flash-preview-04-17 (cheap, DOM mode, no vision cost).
# Other options: gpt-4o-mini, gemini-2.0-flash, claude-haiku-4-5-20251001
STAGEHAND_MODEL=google/gemini-2.5-flash
# API key for the chosen model provider (Google AI, OpenAI, Anthropic, etc.)
STAGEHAND_API_KEY=
# Set to false to disable action caching (caching speeds up repeated runs)
STAGEHAND_USE_CACHE=true
