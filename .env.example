QUOTE_TOOL_ARTIFACT_ROOT=./artifacts
QUOTE_TOOL_STORAGE_ROOT=./storage
QUOTE_TOOL_HEADED=false
QUOTE_TOOL_PORT=4310

# Optional. If omitted, Quoteget will generate a disposable Mailinator address per Hubs run.
HUBS_EMAIL=
HUBS_UNITS=mm
HUBS_FINISH_SLUG=as-machined-standard
HUBS_MATERIAL_SUBSET_ID=124
HUBS_TECHNOLOGY_ID=1

XOMETRY_STORAGE_STATE=./storage/auth/xometry.json
RAPIDDIRECT_STORAGE_STATE=./storage/auth/rapiddirect.json
PROTOLABS_STORAGE_STATE=./storage/auth/protolabs.json
