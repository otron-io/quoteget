{
  "name": "quoteget",
  "version": "0.1.0",
  "description": "One STEP file in, the same file sent to multiple CNC quote vendors.",
  "type": "module",
  "bin": {
    "quote": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "serve": "node dist/cli.js serve",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=24.14.1"
  },
  "license": "MIT",
  "dependencies": {
    "commander": "14.0.3",
    "express": "5.1.0",
    "multer": "2.0.2",
    "playwright": "1.59.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/express": "5.0.5",
    "@types/multer": "2.0.0",
    "@types/node": "24.10.1",
    "jsdom": "27.1.0",
    "supertest": "7.1.4",
    "tsx": "4.21.0",
    "typescript": "6.0.2",
    "vitest": "4.1.2"
  }
}
